{
  "name": "oil-price-chart-backend",
  "version": "1.0.0",
  "description": "Backend for WTI Crude Oil price chart application",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "backup": "node utils/backup.js --prune",
    "backup:list": "node -e \"const b=require('./utils/backup');console.table(b.listBackups())\"",
    "backup:restore": "node utils/backup.js --restore"
  },
  "dependencies": {
