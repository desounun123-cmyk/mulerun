# ─── Server ───────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Allowed Origin (host header injection protection) ───────────
# ALLOWED_ORIGIN=https://oil-benchmarks.com

# ─── Reverse Proxy / Trust Proxy ─────────────────────────────────
TRUST_PROXY=1

# ─── Logging ─────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_DIR=./logs
# LOG_MAX_SIZE=10485760
# LOG_ROTATION_INTERVAL=daily
# LOG_MAX_FILES=14

# ─── Database ─────────────────────────────────────────────────────
# DB_PATH=./data.db

# ─── Session ──────────────────────────────────────────────────────
SESSION_SECRET=
COOKIE_SECURE=false
COOKIE_MAX_AGE_DAYS=7

# ─── TLS / HTTPS ─────────────────────────────────────────────────
# Commented out for development — server starts in plain HTTP mode.
# Uncomment after certbot populates certs/ or when using mkcert for local HTTPS.
# TLS_CERT_PATH=./certs/fullchain.pem
# TLS_KEY_PATH=./certs/privkey.pem
# TLS_CA_PATH=./certs/chain.pem
# HTTP_PORT=80

# ─── Let's Encrypt / Certbot ─────────────────────────────────────
# CERTBOT_DOMAIN=oil-benchmarks.com
# CERTBOT_EMAIL=admin@oil-benchmarks.com
# CERTBOT_METHOD=standalone
# CERTBOT_WEBROOT=./public

# ─── Account Lockout ─────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ─── SMTP (password reset emails) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OIL Benchmarks" <noreply@oil-benchmarks.com>

# ─── Backups ─────────────────────────────────────────────────────
# BACKUP_DIR=./backups
BACKUP_RETAIN_COUNT=10
# BACKUP_DISABLED=true
#
# ── Hourly backups ──────────────────────────────────────────────
BACKUP_HOURLY_ENABLED=true
BACKUP_HOURLY_INTERVAL_MIN=60
BACKUP_HOURLY_RETAIN=24
#
# ── Daily backups ───────────────────────────────────────────────
BACKUP_DAILY_ENABLED=true
BACKUP_DAILY_HOUR_UTC=2
BACKUP_DAILY_RETAIN=30
#
# ── Point-in-Time Recovery (PITR) ──────────────────────────────
PITR_ENABLED=true 
PITR_RETAIN_HOURS=168 

# ─── Cleanup (expired sessions & tokens) ─────────────────────────
# CLEANUP_INTERVAL_MIN=15

# ─── Price Checker (server-side email alerts) ──────────────────
PRICE_CHECK_INTERVAL_MIN=15
# EIA_API_KEY=DEMO_KEY
# PRICE_CHECK_DISABLED=true

# ─── News Feed (ticker headlines) ────────────────────────────
# NEWS_API_KEY=your_newsapi_key_here
# MEDIASTACK_KEY=your_mediastack_key_here
# NEWS_CACHE_TTL_MS=300000

# ─── Helmet (security headers) ───────────────────────────────
# Set to true to disable Helmet entirely (for dev/preview only)
# DISABLE_HELMET=true

# ─── Cron jobs (recommended for production) ──────────────────────
# Database backup — install with:
#   crontab -l | { cat; echo "0 */6 * * * /path/to/server/scripts/cron-backup.sh >> /path/to/server/backups/cron.log 2>&1"; } | crontab -
# Or daily at 3 AM:
#   0 3 * * * /path/to/server/scripts/cron-backup.sh >> /path/to/server/backups/cron.log 2>&1
#
# Certificate renewal — twice daily (certbot skips if not near expiry):
#   30 2,14 * * * /path/to/server/scripts/renew-certs.sh >> /path/to/server/logs/cert-renewal.log 2>&1
