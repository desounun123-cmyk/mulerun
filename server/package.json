{
  "name": "oil-price-chart-backend",
  "version": "1.0.0",
  "description": "Backend for WTI Crude Oil price chart application",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "backup": "node backup.js --prune",
    "backup:list": "node -e \"const b=require('./backup');console.table(b.listBackups())\"",
    "backup:restore": "node backup.js --restore"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "better-sqlite3-session-store": "^0.1.0",
    "compression": "^1.8.1",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.17.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "helpers\\.js$"
    ]
  }
}
