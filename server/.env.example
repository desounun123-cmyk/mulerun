# ─── Server ───────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────
# DB_PATH=./data.db

# ─── Session ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
COOKIE_SECURE=false
COOKIE_MAX_AGE_DAYS=7

# ─── SMTP (password reset emails) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OIL Benchmarks" <noreply@oil-benchmarks.com>
