# ─── Server ───────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Logging ─────────────────────────────────────────────────────
# Log level: fatal, error, warn, info, debug, trace (default: debug in dev, info in prod)
# LOG_LEVEL=info
# Directory for log files in production (default: ./logs)
# LOG_DIR=./logs
# Max bytes per log file before rotation (default: 10485760 = 10 MB)
# LOG_MAX_SIZE=10485760
# Time-based rotation: "daily", "hourly", or seconds (default: daily)
# LOG_ROTATION_INTERVAL=daily
# Number of rotated log files to retain (default: 14)
# LOG_MAX_FILES=14

# ─── Database ─────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file
# DB_PATH=./data.db

# ─── Session ──────────────────────────────────────────────────────
# A persistent secret so sessions survive server restarts.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left empty, a random secret is generated on each start (invalidates existing sessions).
SESSION_SECRET=
COOKIE_SECURE=false
COOKIE_MAX_AGE_DAYS=7

# ─── Account Lockout ─────────────────────────────────────────────
# Lock account after N consecutive failed login attempts
LOGIN_MAX_ATTEMPTS=5
# Lock duration in minutes
LOGIN_LOCKOUT_MINUTES=15

# ─── SMTP (password reset emails) ────────────────────────────────
# Leave blank to use Ethereal test accounts (dev mode — emails captured, not delivered)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OIL Benchmarks" <noreply@oil-benchmarks.com>

# ─── OAuth (Google) ───────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth (GitHub) ───────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:8080/api/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Backups ─────────────────────────────────────────────────────
# Directory for backup files (default: ./backups)
# BACKUP_DIR=./backups
# Number of backups to retain (oldest pruned automatically)
BACKUP_RETAIN_COUNT=10
# In-process backup interval in hours (set BACKUP_DISABLED=true to rely solely on cron)
BACKUP_INTERVAL_HOURS=6
# BACKUP_DISABLED=true
#
# ─── Price Checker (server-side email alerts) ──────────────────
# Check interval in minutes (default: 15)
PRICE_CHECK_INTERVAL_MIN=15
# EIA API key (default: DEMO_KEY — rate-limited; get a free key at https://www.eia.gov/opendata/)
# EIA_API_KEY=DEMO_KEY
# Set to true to disable the server-side price checker
# PRICE_CHECK_DISABLED=true
#
# ─── Cron setup (run once to install) ────────────────────────────
# crontab -l | { cat; echo "0 */6 * * * $(pwd)/cron-backup.sh >> $(pwd)/backups/cron.log 2>&1"; } | crontab -
