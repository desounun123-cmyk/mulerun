# ─── Server ───────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Allowed Origin (host header injection protection) ───────────
# The public URL of your application. Used to build password-reset, email-
# verification, and OAuth callback URLs instead of trusting the Host header.
# Comma-separate multiple origins for staging + production.
# Examples: https://oil-benchmarks.com
#           https://oil-benchmarks.com,https://staging.oil-benchmarks.com
# ALLOWED_ORIGIN=https://oil-benchmarks.com

# ─── Reverse Proxy / Trust Proxy ─────────────────────────────────
# How many proxy hops to trust for X-Forwarded-* headers (affects req.ip, req.protocol).
# Examples: 1 (single nginx), 2 (Cloudflare + nginx), "10.0.0.0/8" (trusted subnet),
#           true (trust all — only in fully controlled networks), false (trust none).
# Default: 1
TRUST_PROXY=1

# ─── Logging ─────────────────────────────────────────────────────
# Log level: fatal, error, warn, info, debug, trace (default: debug in dev, info in prod)
# LOG_LEVEL=info
# Directory for log files in production (default: ./logs)
# LOG_DIR=./logs
# Max bytes per log file before rotation (default: 10485760 = 10 MB)
# LOG_MAX_SIZE=10485760
# Time-based rotation: "daily", "hourly", or seconds (default: daily)
# LOG_ROTATION_INTERVAL=daily
# Number of rotated log files to retain (default: 14)
# LOG_MAX_FILES=14

# ─── Database ─────────────────────────────────────────────────────
# DB_PATH=./data.db

# ─── WAL Checkpoint Management ───────────────────────────────────
# SQLite WAL (Write-Ahead Log) settings. The server runs in WAL mode
# for better concurrent read/write performance.
#
# Auto-checkpoint threshold in pages. SQLite auto-checkpoints when the
# WAL reaches this many pages. Default: 1000 (~4 MB with 4096 page size).
# Set to 0 to disable auto-checkpoint (manual/scheduled only).
# WAL_AUTOCHECKPOINT=1000
#
# Background health monitor: periodic PASSIVE checkpoint interval (minutes).
# Keeps the WAL file small without blocking writers. Default: 5
# DB_CHECKPOINT_INTERVAL_MIN=5
#
# Background integrity check interval (minutes). Scans the entire database
# for corruption. On failure, auto-recovery from the newest valid backup
# is attempted. Default: 60
# DB_INTEGRITY_INTERVAL_MIN=60

# ─── Session ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
COOKIE_SECURE=false
COOKIE_MAX_AGE_DAYS=7

# ─── TLS / HTTPS ─────────────────────────────────────────────────
# Provide certificate and private key paths to enable native HTTPS.
# When set, the server listens on PORT over HTTPS and redirects HTTP_PORT → HTTPS.
# Leave commented out for plain HTTP in development.
# In production, use Let's Encrypt via scripts/renew-certs.sh to populate certs/.
# TLS_CERT_PATH=./certs/fullchain.pem
# TLS_KEY_PATH=./certs/privkey.pem
# TLS_CA_PATH=./certs/chain.pem          # optional intermediate CA chain
# HTTP_PORT=80                            # plain-HTTP redirect listener (default: 80)

# ─── Let's Encrypt / Certbot (used by scripts/renew-certs.sh) ────
# Domain name for the certificate (required for renewal script)
# CERTBOT_DOMAIN=oil-benchmarks.com
# Email for Let's Encrypt account notifications (expiry warnings, etc.)
# CERTBOT_EMAIL=admin@oil-benchmarks.com
# Challenge method: "standalone" (needs port 80 free) or "webroot" (serves from a directory)
# CERTBOT_METHOD=standalone
# Webroot path (only used when CERTBOT_METHOD=webroot)
# CERTBOT_WEBROOT=./public

# ─── Account Lockout ─────────────────────────────────────────────
# Lock account after N consecutive failed login attempts
LOGIN_MAX_ATTEMPTS=5
# Lock duration in minutes
LOGIN_LOCKOUT_MINUTES=15

# ─── Registration Anti-Abuse ─────────────────────────────────────
# Comma-separated list of blocked email domains (disposable/temp mail).
# Example: mailinator.com,guerrillamail.com,tempmail.com,throwaway.email
# BLOCKED_EMAIL_DOMAINS=

# ─── Bot Detection (Analytics) ───────────────────────────────────
# Client-side bot score threshold. Pageviews/events with a score >= this
# value are silently discarded. The client fingerprinter runs ~15 checks
# (webdriver, headless UA, missing plugins, etc.) and sums weighted points.
# Score 0 = normal browser. Score 5+ = strong automation signal.
# Lower = stricter (may false-positive), higher = more lenient. Default: 5
# BOT_SCORE_THRESHOLD=5

# ─── SMTP (password reset emails) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OIL Benchmarks" <noreply@oil-benchmarks.com>

# ─── Backups ─────────────────────────────────────────────────────
# Directory for backup files (default: ./backups)
# BACKUP_DIR=./backups
# Legacy: generic retention count for manual / untagged backups
BACKUP_RETAIN_COUNT=10
# Set to true to disable ALL in-process backups
# BACKUP_DISABLED=true
#
# ── Hourly backups ──────────────────────────────────────────────
# Rolling lightweight backups. First one runs immediately on startup.
BACKUP_HOURLY_ENABLED=true
# Interval in minutes between hourly backups (default: 60)
BACKUP_HOURLY_INTERVAL_MIN=60
# How many hourly backups to keep before pruning (default: 24)
BACKUP_HOURLY_RETAIN=24
#
# ── Daily backups ───────────────────────────────────────────────
# Full daily backup aligned to a specific UTC hour.
BACKUP_DAILY_ENABLED=true
# UTC hour (0-23) for the daily backup (default: 2 → 02:00 UTC)
BACKUP_DAILY_HOUR_UTC=2
# How many daily backups to keep before pruning (default: 30)
# Only used when GFS retention is disabled (BACKUP_GFS_ENABLED=false).
BACKUP_DAILY_RETAIN=30
#
# ── GFS Retention Policy (Grandfather-Father-Son) ────────────
# Replaces flat count-based daily pruning with tiered retention.
# When enabled (default), daily backups are classified by age:
#   - Daily:   keep every backup from the last N days
#   - Weekly:  keep 1 backup per week for the previous N weeks
#   - Monthly: keep 1 backup per month for the previous N months
# This provides ~1 year of coverage with minimal disk usage.
BACKUP_GFS_ENABLED=true
# Number of days to keep every daily backup (default: 7)
BACKUP_GFS_DAILY_RETAIN=7
# Number of weeks to keep one weekly backup (default: 4)
BACKUP_GFS_WEEKLY_RETAIN=4
# Number of months to keep one monthly backup (default: 12)
BACKUP_GFS_MONTHLY_RETAIN=12
#
# ── Point-in-Time Recovery (PITR) ──────────────────────────────
# Records every database write to a changelog table, enabling recovery
# to any arbitrary timestamp (not just backup boundaries).
#enable/disable change logging
PITR_ENABLED=true 
# How many hours of changelog history to retain (default: 168 = 7 days)
# keep 7 days of changelog
PITR_RETAIN_HOURS=168

# ─── Cleanup (expired sessions & tokens) ─────────────────────────
# How often to purge expired sessions, password-reset tokens, and email-
# verification tokens (in minutes). Runs as a background job inside the server.
# Default: 15
# CLEANUP_INTERVAL_MIN=15

# ─── Price Checker (server-side email alerts) ──────────────────
# Check interval in minutes (default: 15)
PRICE_CHECK_INTERVAL_MIN=15
# EIA API key (default: DEMO_KEY — rate-limited; get a free key at https://www.eia.gov/opendata/)
# EIA_API_KEY=DEMO_KEY
# Set to true to disable the server-side price checker
# PRICE_CHECK_DISABLED=true

# ─── News Feed (ticker headlines) ────────────────────────────
# Oil & energy headlines from external APIs, displayed in the ticker banner.
# At least one key is required for news to appear; both can be used together.
# NewsAPI.org — free tier: 100 requests/day. Sign up: https://newsapi.org/register
# NEWS_API_KEY=your_newsapi_key_here
# Mediastack — free tier: 500 requests/month. Sign up: https://mediastack.com/signup
# MEDIASTACK_KEY=your_mediastack_key_here
# Cache TTL in milliseconds (default: 300000 = 5 minutes)
# NEWS_CACHE_TTL_MS=300000

# ─── Helmet (security headers) ───────────────────────────────
# Set to true to disable Helmet entirely (for sandbox/preview iframe embedding).
# In production, leave unset so all security headers are active.
# DISABLE_HELMET=true

# ─── Cron jobs (recommended for production) ──────────────────────
# Database backup — install with:
#   crontab -l | { cat; echo "0 */6 * * * /path/to/server/scripts/cron-backup.sh >> /path/to/server/backups/cron.log 2>&1"; } | crontab -
# Or daily at 3 AM:
#   0 3 * * * /path/to/server/scripts/cron-backup.sh >> /path/to/server/backups/cron.log 2>&1
#
# Certificate renewal — twice daily (certbot skips if not near expiry):
#   30 2,14 * * * /path/to/server/scripts/renew-certs.sh >> /path/to/server/logs/cert-renewal.log 2>&1

