    "better-sqlite3": "^9.4.3",
    "better-sqlite3-session-store": "^0.1.0",
    "compression": "^1.8.1",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "otpauth": "^9.5.0",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-roll": "^4.0.0",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
